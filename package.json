{
  "name": "xhs-data-extension",
  "private": true,
  "version": "1.0.87",
  "type": "module",
  "description": "小红书/红书 数据采集 Chrome 插件",
  "scripts": {
    "dev": "npm run icons && vite",
    "build": "npm run icons && node scripts/bump-version.mjs && vue-tsc --noEmit && vite build",
    "icons": "node scripts/gen-icons.mjs",
    "bump": "node scripts/bump-version.mjs",
    "preview": "vite preview",
    "pack": "node scripts/pack.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.0.298",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.4",
    "vue-tsc": "^2.2.0"
  }
}
